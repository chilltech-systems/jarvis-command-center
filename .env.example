NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Optional server-only Ava Assistant integrations. Never prefix secrets with NEXT_PUBLIC_.
OPENAI_API_KEY=YOUR_SERVER_SIDE_OPENAI_KEY
OPENAI_MODEL=gpt-5.4
# Optional realtime voice overrides for the immersive Cognitive Nebula.
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
N8N_API_URL=https://YOUR_N8N_HOST
N8N_API_KEY=YOUR_SERVER_SIDE_N8N_KEY

# Preserved compatibility names for the existing Tool Hub contract.
JARVIS_TOOL_HUB_URL=https://YOUR_N8N_HOST/webhook/jarvis-tools
JARVIS_TOOL_HUB_TOKEN=YOUR_SERVER_SIDE_TOOL_HUB_TOKEN
GOOGLE_GMAIL_CREDENTIAL=YOUR_SERVER_SIDE_REFERENCE
GOOGLE_CALENDAR_CREDENTIAL=YOUR_SERVER_SIDE_REFERENCE
GOOGLE_DRIVE_CREDENTIAL=YOUR_SERVER_SIDE_REFERENCE
SLACK_BOT_TOKEN=YOUR_SERVER_SIDE_SLACK_TOKEN
GITHUB_TOKEN=YOUR_SERVER_SIDE_GITHUB_TOKEN

# Future Ava live integrations. Keep secrets server-side.
AVA_WEATHER_LOCATION=The Woodlands, TX
AVA_WEATHER_API_KEY=YOUR_SERVER_SIDE_WEATHER_KEY
AVA_CALENDAR_PROVIDER=google
AVA_TASK_PROVIDER=todoist
AVA_PROJECTS_SOURCE=local
AVA_NOTIFICATIONS_ENABLED=false

# Read-only server-to-server feed for the owner-only AVA Cognitive Nebula.
AVA_NEBULA_FEED_TOKEN=YOUR_LONG_RANDOM_SERVER_SIDE_TOKEN

# Local-only Codex runner. Do not expose service-role keys to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_LOCAL_RUNNER_SERVICE_ROLE_KEY
JARVIS_CODEX_COMMAND=codex
JARVIS_CODEX_DRY_RUN=0
JARVIS_CODEX_POLL_MS=15000
